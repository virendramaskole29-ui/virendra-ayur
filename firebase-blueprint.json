{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An Ayurvedic product in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "benefits": { "type": "array", "items": { "type": "string" } },
        "ingredients": { "type": "array", "items": { "type": "string" } },
        "usage": { "type": "string" },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "pincode": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered", "cancelled"] },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "customerName", "customerEmail", "total", "status"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Admin user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Admin users"
    }
  }
}
